# =============================================================================
# Vecto Pilot — .env.local.example (template)
# =============================================================================
# Copy to .env.local and fill in the empty values below — OR set them as
# Replit Secrets and reference them with ${VAR_NAME} (preferred).
#
# Loaded at boot by server/config/load-env.js (dev/workspace path).
# In Replit deployments (REPLIT_DEPLOYMENT=1) Replit Secrets are the sole
# source of truth and this file is skipped.
#
# Model-agnostic adapter pattern (CLAUDE.md Rule 14):
#   Each AI role has a {ROLE}_MODEL var. The adapter routes by model prefix
#   (gpt-/o*- → OpenAI, claude- → Anthropic, gemini- → Google), so swapping
#   a role's model never touches API-key plumbing.
#
# Canonical role catalogue (single source of truth):
#   .code_based_rules/.rules_do_not_change/llm_calls_audit.md
# =============================================================================

# ─── 1. Server / Runtime ─────────────────────────────────────────────────────
APP_MODE=mono
PORT=5000
GATEWAY_PORT=5000
NODE_ENV=development
DISABLE_SPAWN_SDK=1
DISABLE_SPAWN_AGENT=1
API_PREFIX=/api
AGENT_PREFIX=/agent
WS_PUBLIC_PATH=/agent/ws
SOCKET_IO_PATH=/socket.io
ENABLE_BACKGROUND_WORKER=true
SEED_JOB_ON_BOOT=true
USE_LISTEN_MODE=false
BASE_DIR=/home/runner/workspace
STATE_DIR=./data/state
SNAPSHOT_DIR=./data/snapshots
CONTEXT_CACHE_DIR=./data/cache

# ─── 2. Database ─────────────────────────────────────────────────────────────
# DATABASE_URL is auto-injected by Replit (Helium in dev, Neon serverless in
# prod — see CLAUDE.md Rule 13). Do NOT hardcode here.
PG_USE_SHARED_POOL=true
PG_MAX=10
PG_MIN=2
PG_IDLE_TIMEOUT_MS=120000
PG_CONNECTION_TIMEOUT_MS=10000
PG_KEEPALIVE=true
PG_KEEPALIVE_DELAY_MS=30000
PG_MAX_USES=7500

# ─── 3. Provider API Keys ────────────────────────────────────────────────────
# Set as Replit Secrets and the loader will resolve ${VAR_NAME} at boot.
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY1=
STRATEGIST_ANTHROPIC_API_KEY=
VECTO_CLAUDE=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLEAQ_API_KEY=
PERPLEXITY_API_KEY=
TOMTOM_API_KEY=
NEWS_API_KEY=
OPENWEATHER_API_KEY=
RESEND_API_KEY=
SERP_API_KEY=
TIMEZONE_API_KEY=

# ─── 4. Auth Tokens ──────────────────────────────────────────────────────────
# Generate locally with: openssl rand -hex 32
JWT_SECRET=
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=
AGENT_TOKEN=
AGENT_KEY=
ASSISTANT_KEY=
GW_KEY=
SDK_TOKEN=
MCP_TOKEN=
MCP_REPLIT_TOKEN=
VITE_MCP_REPLIT_TOKEN=
VECTO_AGENT_SECRET=
AI_COACH_TOKEN=
EIDOLON_TOKEN=

# ─── 5. Uber OAuth ───────────────────────────────────────────────────────────
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_REDIRECT_URI=
UBER_WEBHOOK_SECRET=

# ─── 6. AI Models — Canonical Role Names (Rule 14) ───────────────────────────
# Each role is consumed by callModel(role, ...) via server/lib/ai/adapters/.
# Source of truth: .code_based_rules/.rules_do_not_change/llm_calls_audit.md
#
# Briefings (Gemini with Google Search Grounding throughout)
BRIEFING_FALLBACK_MODEL=gemini-3.1-pro-preview
BRIEFING_TRAFFIC_MODEL=gemini-3.1-pro-preview
BRIEFING_EVENTS_DISCOVERY_MODEL=gemini-3.1-pro-preview
BRIEFING_WEATHER_MODEL=gemini-3.1-pro-preview
BRIEFING_SCHOOLS_MODEL=gemini-3.1-pro-preview
BRIEFING_AIRPORT_MODEL=gemini-3.1-pro-preview
BRIEFING_NEWS_MODEL=gemini-3.1-pro-preview
BRIEFING_HOLIDAY_MODEL=gemini-3.1-pro-preview
# Strategy pipeline (snapshot context → tactical plan → daily summary)
STRATEGY_CONTEXT_MODEL=gemini-3.1-pro-preview
STRATEGY_TACTICAL_MODEL=gpt-5.5-2026-04-23
STRATEGY_DAILY_MODEL=gemini-3.1-pro-preview
# Venue intelligence (ranking_candidates table)
VENUE_SCORER_MODEL=gpt-5.5-2026-04-23
VENUE_FILTER_MODEL=claude-haiku-4-5-20251001
VENUE_TRAFFIC_MODEL=gemini-3.1-pro-preview
VENUE_EVENT_VERIFIER_MODEL=gemini-3.1-pro-preview
# Conversational (coach + concierge)
AI_COACH_MODEL=gemini-3.1-pro-preview
CONCIERGE_SEARCH_MODEL=gemini-3.1-pro-preview
CONCIERGE_CHAT_MODEL=gemini-3.1-pro-preview
# Offer analyzer (Siri shortcut + DB enrichment)
OFFER_ANALYZER_MODEL=gemini-3-flash-preview
OFFER_ANALYZER_DEEP_MODEL=gemini-3.1-pro-preview
# Validators / utilities
UTIL_WEATHER_VALIDATOR_MODEL=gemini-3.1-pro-preview
UTIL_TRAFFIC_VALIDATOR_MODEL=gemini-3.1-pro-preview
UTIL_RESEARCH_MODEL=gemini-3.1-pro-preview
UTIL_TRANSLATION_MODEL=gemini-3.1-flash-lite-preview
UTIL_MARKET_PARSER_MODEL=gpt-5.5-2026-04-23

# ─── 6a. Legacy Validator Aliases ────────────────────────────────────────────
# Still consumed by server/config/env-registry.js + validate-env.js for
# boot-time logging. NOT used by callModel(role, ...). Safe to keep.
STRATEGY_STRATEGIST=claude-opus-4-7
STRATEGY_BRIEFER=gemini-3.1-pro-preview
STRATEGY_CONSOLIDATOR=gpt-5.5-2026-04-23
STRATEGY_EVENT_VALIDATOR=claude-opus-4-7
STRATEGY_VENUE_PLANNER=gpt-5.5-2026-04-23

# ─── 7. Subagent Override Models (Agent / Assistant / Eidolon / Coach) ───────
AGENT_OVERRIDE_PROVIDER=anthropic
AGENT_OVERRIDE_MODEL=claude-opus-4-7
AI_COACH_OVERRIDE_PROVIDER=google
AI_COACH_OVERRIDE_MODEL=gemini-3.1-pro-preview
EIDOLON_OVERRIDE_PROVIDER=anthropic
EIDOLON_OVERRIDE_MODEL=claude-opus-4-7
AGENT_MODEL=claude-opus-4-7
ASSISTANT_MODEL=claude-opus-4-7
EIDOLON_MODEL=claude-opus-4-7
CLAUDE_MODEL=claude-opus-4-7

# ─── 8. Provider-Level Defaults (apply when role doesn't override) ───────────
ANTHROPIC_MAX_TOKENS=128000
ANTHROPIC_THINKING_ENABLED=true
ANTHROPIC_THINKING_BUDGET=10000
ANTHROPIC_CONTEXT_WINDOW=1000000
ANTHROPIC_THINKING_LOW=1000
ANTHROPIC_THINKING_MEDIUM=5000
ANTHROPIC_THINKING_HIGH=10000

OPENAI_MODEL=gpt-5.5-2026-04-23
OPENAI_REASONING_EFFORT=high
OPENAI_MAX_COMPLETION_TOKENS=128000
OPENAI_CONTEXT_WINDOW=1000000
OPENAI_ENRICH=true

GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_TOKENS=8192
GEMINI_MAX_CONCURRENCY=12
GEMINI_GROUNDING_ENABLED=true

ANTHROPIC_MODEL=claude-opus-4-7

# ─── 9. Timeouts / Budgets (ms) ──────────────────────────────────────────────
LLM_TOTAL_BUDGET_MS=360000
GPT5_TIMEOUT_MS=300000
PLANNER_DEADLINE_MS=300000
VALIDATOR_DEADLINE_MS=60000
DEFAULT_TIMEOUT_MS=180000
API_TIMEOUT_MS=120000
LLM_TIMEOUT_MS=180000
LLM_PRIMARY_TIMEOUT_MS=45000
ANTHROPIC_TIMEOUT_MS=60000
CLAUDE_TIMEOUT_MS=45000
GEMINI_TIMEOUT_MS=60000
BROWSER_GPS_TIMEOUT_MS=8000
COMMAND_EXEC_TIMEOUT_MS=15000
TRANSIENT_RETRY_TIMEOUT_MS=45000
ROUTES_API_FUTURE_TIME_MS=30000
TRANSIENT_RETRY_MAX_RETRIES=6
CIRCUIT_COOLDOWN_MS=60000

# ─── 10. Triad Pipeline Control ──────────────────────────────────────────────
TRIAD_ENABLED=true
TRIAD_MODE=single_path
TRIAD_FAIL_ON_INVALID=true
TRIAD_INVARIANT_NO_VENUE_INVENTION=true
TRIAD_INVARIANT_SCHEMA_STRICT=true
TRIAD_INVARIANT_WORD_CAPS=true
TRIAD_STRATEGIST_PROVIDER=openai
TRIAD_PLANNER_PROVIDER=openai
TRIAD_VALIDATOR_PROVIDER=openai

# ─── 11. Agent / Assistant / Eidolon Server ──────────────────────────────────
# Only the vars actually consumed in code remain. The legacy AGENT_ALLOW_*,
# *_DESIGN_MODE, *_ENHANCED_*, *_MEMORY_*, *_THREAD_*, *_THINKING_* flags
# (~390 lines) had 0 code references and were removed 2026-04-30.
AGENT_ENABLED=true
AGENT_OVERRIDE_MODE=true
AGENT_PORT=43717
AGENT_HOST=127.0.0.1
AGENT_BASE_URL=http://127.0.0.1:43717
AGENT_URL=http://127.0.0.1:43717
AGENT_POLICY_PATH=config/agent-policy.json
AGENT_PERSIST=true
AGENT_PERPLEXITY_ENABLED=true
AGENT_GOOGLE_SEARCH_ENABLED=true
AGENT_SHELL_WHITELIST=*
AGENT_MAX_TOKENS=128000
AGENT_TEMPERATURE=0.2
AGENT_ADMIN_USERS=
AGENT_ALLOWED_IPS=

ASSISTANT_ENABLED=true
ASSISTANT_BASE_URL=http://127.0.0.1:43717
ASSISTANT_POLICY_PATH=config/assistant-policy.json
ASSISTANT_PERSIST=true
ASSISTANT_MEMORY_TABLE=agent_memory

AI_COACH_MODE=true

EIDOLON_OVERRIDE_MODE=true
EIDOLON_PORT=3101
EIDOLON_BASE_URL=http://127.0.0.1:43717
EIDOLON_POLICY_PATH=config/eidolon-policy.json
EIDOLON_PERSIST=true
EIDOLON_MEMORY_TABLE=eidolon_memory

# ─── 12. Vertex AI / Google Cloud ────────────────────────────────────────────
# load-env.js reconstructs /tmp/gcp-credentials.json from individual Replit
# Secrets fields (type, project_id, private_key, client_email, etc.).
# load-env.js also auto-derives GOOGLE_CLOUD_PROJECT from GOOGLE_CLOUD_PROJECT_ID.
VERTEX_AI_ENABLED=true
GOOGLE_CLOUD_LOCATION=us-central1

# ─── 13. Client (Vite — read at build time, must be VITE_*) ──────────────────
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=
VITE_COACH_STREAMING_TTS=true
VITE_DEBUG_MAP=false
VITE_DEBUG_VENUES=false
VITE_DEBUG_SSE=false
VITE_DEBUG_BLOCKS=false

# ─── 14. Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_NO_EMOJI=true
LOG_QUIET_COMPONENTS=
LOG_VERBOSE_COMPONENTS=

# ─── 15. Worker / Lock / Rate Limit ──────────────────────────────────────────
LOCK_TTL_MS=9000
HEARTBEAT_MS=3000
WORKER_ID=replit:primary
MAX_WORKER_RESTARTS=10
RESTART_BACKOFF_MS=5000
JOB_CLEANUP_INTERVAL_MS=3600000
MAX_REQUESTS_PER_WINDOW=10
RATE_LIMIT_WINDOW_MS=60000

# ─── 16. Research / Web Search Defaults ──────────────────────────────────────
PERPLEXITY_ENABLED=false
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_MAX_TOKENS=4096
WEB_SEARCH_ENABLED=true

# ─── 17. Geospatial / Ranking Constants ──────────────────────────────────────
EARTH_RADIUS_KM=6371
COORD_DELTA_THRESHOLD_KM=0.5
AIRPORT_PROXIMITY_THRESHOLD_MILES=30
MAX_BLOCKS_LIMIT=50
MIN_BLOCKS_RECOMMENDED=8
EXPLORATION_RATE=0.2
OPEN_PROB_DEFAULT=0.5
RELIABILITY_DEFAULT=0.5
PROXIMITY_WEIGHT=2.0
CACHE_WINDOW_MINUTES=1
SEMANTIC_EMBEDDING_SIZE=1536

# ─── 18. Value Per Minute Ranking ────────────────────────────────────────────
VALUE_BASE_RATE_PER_MIN=1.00
VALUE_DEFAULT_TRIP_MIN=15
VALUE_DEFAULT_WAIT_MIN=0
VALUE_MIN_ACCEPTABLE_PER_MIN=0.50

# ─── 19. Model Sampling Defaults ─────────────────────────────────────────────
MODEL_TEMPERATURE=0.0
MODEL_TOP_K=40
MODEL_TOP_P=0.8

# ─── 20. Replit Metadata (managed by Replit, do not edit) ────────────────────
REPL_ID=
REPL_OWNER=
REPL_SLUG=
REPLIT_DEV_DOMAIN=
