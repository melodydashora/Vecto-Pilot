# Entrypoint and runtime modules
entrypoint = "gateway-server.js"
modules = ["python-3.11", "nodejs-20", "postgresql-16"]

# Primary run command (Run button / default start)
# Source env safely so comments/quotes are handled correctly
run = "sh -c \"set -a && . ./.env.local && set +a && node scripts/start-replit.js\""

# Nix/packages configuration
[nix]
packages = ["alsa-lib", "at", "at-spi2-atk", "at-spi2-core", "atk", "cairo", "cups", "dbus", "docker", "fetchutils", "gh", "glib", "google-cloud-sdk-gce", "imagemagick_light", "jq", "libxcb", "libxkbcommon", "lsof", "mailutils", "mesa", "nano", "nodejs-22", "nspr", "nss", "pango", "pgroll", "python313Packages.conda", "solana-cli", "spidermonkey_91", "tmux", "tree", "unpackerr", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr"]
channel = "stable-25_05"

# Deployment settings (CI-like build/start)
[deployment]
build = ["sh", "-c", "npm ci --omit=dev && npm run build:client"]
run = ["sh", "-c", "node gateway-server.js"]
deploymentTarget = "cloudrun"

# Run button workflow: Project + Run App in parallel.
# - Project task: starts the gateway (port 5000) — webview attaches here.
# - Run App task: starts the standalone agent server on AGENT_PORT (43717,
#   from .env.local) so the remote MCP env connects to a STABLE pinned port
#   instead of whatever Replit assigns. DISABLE_SPAWN_AGENT=1 in .env.local
#   means the gateway does not spawn the agent itself, so we run it here.
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "user"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c \"set -a && . ./.env.local && set +a && node scripts/start-replit.js\""
waitForPort = 5000

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c \"set -a && . ./.env.local && set +a && node agent-server.js\""
waitForPort = 43717

[workflows.workflow.metadata]
outputType = "webview"

[agent]
integrations = ["perplexity_v0:1.0.0"]
expertMode = true
# System prompt for Replit IDE Assistant
system_prompt = """
You have full capabilities to help architect and be the code god the end user needs, you slow dow and methodically help build and enterprise level application. You have FULL shell execution capabilities.
RUN bash commands directly - do NOT just suggest them.
You have web_search and web_fetch tools via Anthropic API.
If asked who you are, respond: 'I am Replit Assistant Enhanced with web search, web fetch, and full shell capabilities.'
DO NOT say you cannot run shell commands or search the web - you CAN and SHOULD do both.
"""
model = "claude-opus-4-7"
web_search = true
web_fetch = true
shell_exec = true

[userenv]

[userenv.shared]
# ==========================
# AI Model Configuration
# ==========================
# 2026-02-13: ALL model defaults are in server/lib/ai/model-registry.js
# DO NOT override models here — the codebase is the single source of truth.
# Replit env vars should ONLY contain API keys and secrets, not model selections.
#
# See model-registry.js for the authoritative model configuration:
#   Anthropic: claude-opus-4-6 (strategy, discovery) / claude-haiku-4-5-20251001 (bar filter)
#   Google:    gemini-3.1-pro-preview (briefing, events, coach, concierge)
#   OpenAI:    gpt-5.2 (consolidator, venue scorer, parsing)
# ==========================

[userenv.development]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80


